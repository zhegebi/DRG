{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dev: frontend",
            "type": "npm",
            "path": "client",
            "script": "dev",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "group": "dev-group"
            },
            "problemMatcher": {
                "owner": "typescript",
                "pattern": {
                    "regexp": "^.*$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE",
                    "endsPattern": "ready in"
                }
            }
        },
        {
            "label": "dev: backend",
            "type": "shell",
            "command": "uv run uvicorn server.main:app --reload --port 8000",
            "isBackground": true,
            "presentation": {
                "reveal": "silent",
                "group": "dev-group"
            },
            "problemMatcher": {
                "owner": "python",
                "pattern": {
                    "regexp": "^.*$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Waiting for application startup",
                    "endsPattern": "Application startup complete"
                }
            }
        },
        {
            "label": "dev server",
            "dependsOn": [
                "dev: frontend",
                "dev: backend"
            ],
            "runOptions": {
                "runOn": "folderOpen"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}